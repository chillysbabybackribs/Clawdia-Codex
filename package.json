{
  "name": "clawdia-codex",
  "version": "8.0.0",
  "description": "AI desktop workspace with multi-provider chat and embedded browser.",
  "author": "Daniel Parker",
  "license": "MIT",
  "main": "dist/main/main.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "rebuild:native": "node ./node_modules/@electron/rebuild/lib/cli.js -f -w better-sqlite3 -v 36.3.0",
    "postinstall": "npm run rebuild:native",
    "predev": "npm run rebuild:native && tsc -p tsconfig.main.json",
    "dev": "concurrently --kill-others-on-fail \"npm run dev:main\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "safe-dev": "npm run build && npm run start:stable",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5174 dist/main/main.js dist/main/preload.js && nodemon --delay 1 --watch dist/main --exec \"cross-env NODE_ENV=development electron --no-sandbox .\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start:stable": "cross-env NODE_ENV=development electron --no-sandbox .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "better-sqlite3": "^11.9.1",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^9.1.0",
    "remark-gfm": "^4.0.1",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^36.3.0",
    "nodemon": "^3.1.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.3",
    "wait-on": "^8.0.3"
  }
}
